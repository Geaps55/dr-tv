# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key: used by the seed script and admin writes.
# NEVER expose this to the browser. No NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Admin panel ---
# Password for /admin login (v1: single shared password)
ADMIN_PASSWORD=change-me
# Secret used to sign the admin session cookie
ADMIN_SESSION_SECRET=generate-a-long-random-string

# --- AdSense ---
# Not required in dev; site_settings.adsense_client_id overrides this if set.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
